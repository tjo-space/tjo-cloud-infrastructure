{
	metrics {
		per_host
	}
	log {
		format console
		output stdout
	}
	servers {
		listener_wrappers {
			proxy_protocol {
				timeout 2s
				# Using comment hack here. Otherwise caddy fmt takes the template
				#  curly brackets and tries to "format them", which breaks things.
				# {{ "\n allow " + (tjo_cloud_networks | join(' ')) }}
				fallback_policy reject
			}
			tls {
				issuer acme {
					disable_http_challenge
				}
			}
		}
	}
}

##
# GRAFANA
##
monitor.tjo.cloud {
	log
	reverse_proxy localhost:3000 {
		header_up Host {http.request.host}
		health_uri /api/health
		health_port 3000
	}
}

monitor.cloud.internal {
	log

	tls {
		issuer acme {
			dir https://ca.cloud.internal/acme/v1/directory
		}
	}

	reverse_proxy localhost:3000 {
		header_up Host {http.request.host}
		health_uri /api/health
		health_port 3000
	}
}

##
# OTEL
##
grpc.otel.monitor.tjo.cloud,
otel.monitor.tjo.cloud {
	log
	reverse_proxy h2c://localhost:4317
}

grpc.otel.monitor.cloud.internal,
otel.monitor.cloud.internal {
	log
	tls {
		issuer acme {
			dir https://ca.cloud.internal/acme/v1/directory
		}
	}

	reverse_proxy h2c://localhost:4317
}
