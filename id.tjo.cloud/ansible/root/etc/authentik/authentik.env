AUTHENTIK_DISABLE_UPDATE_CHECK=false
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_DISABLE_STARTUP_ANALYTICS=true

AUTHENTIK_AVATARS=initials

AUTHENTIK_STORAGE__BACKEND=file
AUTHENTIK_STORAGE__FILE__PATH=/data

AUTHENTIK_SECRET_KEY={{ authentik_secret_key }}

AUTHENTIK_IMPERSONATION=false

AUTHENTIK_LISTEN__TRUSTED_PROXY_CIDRS=10.89.0.1/32,fd6a:e0a3:bb4b:c6b3::1/128

AUTHENTIK_POSTGRESQL__CONN_HEALTH_CHECKS=true
AUTHENTIK_POSTGRESQL__CONN_MAX_AGE=900
AUTHENTIK_POSTGRESQL__SSLMODE=require
AUTHENTIK_POSTGRESQL__HOST={{ postgresql_host }}
AUTHENTIK_POSTGRESQL__NAME={{ postgresql_database }}
AUTHENTIK_POSTGRESQL__USER={{ postgresql_username }}
AUTHENTIK_POSTGRESQL__PASSWORD={{ postgresql_password }}

AUTHENTIK_EMAIL__HOST=mail.tjo.cloud
AUTHENTIK_EMAIL__PORT=465
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__FROM={{ email_username }}
AUTHENTIK_EMAIL__USERNAME={{ email_username }}
AUTHENTIK_EMAIL__PASSWORD={{ email_password }}
